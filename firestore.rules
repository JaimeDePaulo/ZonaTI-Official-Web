rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - role: string (required, enum: ['client', 'technician', 'admin'])
    //   - phone: string
    //   - photoURL: string
    //   - isApproved: bool (for technicians)
    //   - createdAt: timestamp (required)
    //
    // Collection: supportRequests
    // Document ID: requestId
    // Fields:
    //   - clientId: string (required)
    //   - clientName: string
    //   - serviceType: string (required)
    //   - description: string (required)
    //   - status: string (required, enum: ['pending', 'assigned', 'in-progress', 'completed', 'cancelled'])
    //   - technicianId: string
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "JaimeNgleloDePaulo@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isTechnician() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile as 'client' or 'technician'.
      // Only admins can create 'admin' roles.
      allow create: if isOwner(userId) && 
        request.resource.data.role in ['client', 'technician'] &&
        request.resource.data.uid == userId;
        
      // Only admins can update roles or approval status.
      // Users can update their own non-sensitive info.
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.uid == resource.data.uid &&
        (!('isApproved' in request.resource.data) || request.resource.data.isApproved == resource.data.isApproved)
      );
    }

    match /supportRequests/{requestId} {
      // Clients can read their own requests. Technicians can read assigned or pending. Admins all.
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.technicianId == request.auth.uid ||
        isTechnician() ||
        isAdmin()
      );
      
      // Clients can create requests.
      allow create: if isAuthenticated() && 
        request.resource.data.clientId == request.auth.uid &&
        request.resource.data.status == 'pending';
        
      // Clients can update their own pending requests.
      // Technicians can update status of assigned requests.
      // Admins can update anything.
      allow update: if isAdmin() || (
        isAuthenticated() && (
          (resource.data.clientId == request.auth.uid && resource.data.status == 'pending') ||
          (resource.data.technicianId == request.auth.uid) ||
          (isTechnician() && resource.data.status == 'pending')
        )
      );
    }
  }
}
